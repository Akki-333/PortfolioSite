    "start": "node api/index.js"
  },
  "dependencies": {
    "vite": "^5.4.19",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.1",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}